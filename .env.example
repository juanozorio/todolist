# ============================================================
# TodoList Frontend - Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Build-time (Vite dev server) ---
VITE_API_URL=http://localhost:8080    # Backend API URL for local development

# --- Runtime (Docker container / Kubernetes) ---
API_UPSTREAM=task-api:8080            # Backend host:port for nginx proxy_pass
